#!/usr/bin/env bash

# .bashrc hash: {{ includeTemplate ".chezmoitemplates/file-hash.tmpl" (joinPath .chezmoi.homeDir ".bashrc") }}

{{ if and .is_work (eq .chezmoi.os "linux") -}}
source "{{ .chezmoi.sourceDir }}/scripts/manage_block.sh"

BASHRC_CONTENT='if [[ -f "$HOME/.config/bash/.bashrc" ]]; then
	source "$HOME/.config/bash/.bashrc"
fi'

manage_block "$HOME/.bashrc" "$BASHRC_CONTENT"
{{- end }}
