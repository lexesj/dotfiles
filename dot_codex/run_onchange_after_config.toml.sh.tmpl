#!/usr/bin/env bash

TARGET_FILE="$HOME/.codex/config.toml"
touch "$TARGET_FILE"

tmp=$(mktemp)

# Strip top-level model keys and set tui config; bare keys must precede [sections] in TOML
yq -p toml -o toml 'del(.model_reasoning_effort) | del(.model) | .tui.status_line = ["model-with-reasoning", "current-dir", "context-usage", "five-hour-limit", "weekly-limit"]' "$TARGET_FILE" > "$tmp"

{{ if .is_work -}}
{ yq -n -o toml '.model_reasoning_effort = "high"'; cat "$tmp"; } > "$TARGET_FILE"
{{ end -}}

{{ if .is_personal -}}
{ yq -n -o toml '.model = "gpt-5.5"'; cat "$tmp"; } > "$TARGET_FILE"
{{ end -}}

rm "$tmp"
