#!/usr/bin/env bash

# config.toml hash: {{ includeTemplate ".chezmoitemplates/file-hash.tmpl" (joinPath .chezmoi.homeDir ".codex/config.toml") }}
echo "Updating ~/.codex/config.toml..."

TARGET_FILE="$HOME/.codex/config.toml"
touch "$TARGET_FILE"

tmp=$(mktemp)

# Strip top-level model keys and set tui config; bare keys must precede [sections] in TOML
tomlq -t 'del(.model_reasoning_effort) | del(.model) | .tui.status_line = ["model-with-reasoning", "current-dir", "context-usage", "five-hour-limit", "weekly-limit"] | .tui.vim_mode_default = true' "$TARGET_FILE" > "$tmp"

{{ if .is_work -}}
{ printf '%s\n' 'model_reasoning_effort = "high"'; cat "$tmp"; } > "$TARGET_FILE"
{{ end -}}

{{ if .is_personal -}}
cat "$tmp" > "$TARGET_FILE"
{{ end -}}

rm "$tmp"
