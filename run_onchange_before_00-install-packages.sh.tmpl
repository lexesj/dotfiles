#!/bin/bash

{{ if eq .chezmoi.os "linux" -}}
sudo apt update
sudo apt install -y \
	{{ range .packages.universal.common -}}{{ . }} {{ end -}}
	{{ range .packages.linux.common -}}{{ . }} {{ end -}}
	{{ if .is_work -}}
	{{ range .packages.universal.work -}}{{ . }} {{ end -}}
	{{ range .packages.linux.work -}}{{ . }} {{ end -}}
	{{ else -}}
	{{ range .packages.universal.personal -}}{{ . }} {{ end -}}
	{{ range .packages.linux.personal -}}{{ . }} {{ end -}}
	{{ end }}

# Set zsh as default shell if it's not already
if [[ "$SHELL" != "$(which zsh)" ]]; then
	echo "Changing default shell to zsh..."
	sudo chsh -s "$(which zsh)" "$USER"
fi
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
if command -v brew &> /dev/null; then
	brew bundle --file=/dev/stdin <<-EOF
{{ range .packages.universal.common -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brew.common -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.cask.common -}}
		cask {{ . | quote }}
{{ end -}}
{{ if .is_work -}}
{{ range .packages.universal.work -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brew.work -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.cask.work -}}
		cask {{ . | quote }}
{{ end -}}
{{ else -}}
{{ range .packages.universal.personal -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brew.personal -}}
		brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.cask.personal -}}
		cask {{ . | quote }}
{{ end -}}
{{ end -}}
	EOF
fi
{{ end -}}
