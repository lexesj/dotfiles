# vim: set ft=bash :

# Source shared shell config (functions, variables, PATH).
SHELL_CONFIG_DIR="$HOME/.config/shell"
if [[ -d "$SHELL_CONFIG_DIR" ]]; then
	for file in "$SHELL_CONFIG_DIR"/*.sh; do
		source "$file"
	done
fi

# Vi mode.
set -o vi

# Fzf.
if command -v fzf &>/dev/null; then
	source <(fzf --bash)
fi

# Zoxide.
if command -v zoxide &>/dev/null; then
	eval "$(zoxide init --cmd cd bash)"
fi

# gitfs.
function setup_git() {
	pay gitfs profile dashboard-frontend
	pay gitfs add \
		pay-server/api/lib \
		pay-server/frontend/data-manage \
		pay-server/lib/api_core/test \
		pay-server/lib/bapling_routing \
		pay-server/lib/compliance_hub \
		pay-server/lib/permission/lockfiles \
		pay-server/openapi \
		pay-server/stripe_frontend/config
	pay gitfs watch
}
