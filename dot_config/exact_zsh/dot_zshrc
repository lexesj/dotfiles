# vim: set ft=bash :

# Source shared shell config (functions, variables, PATH).
SHELL_CONFIG_DIR="$HOME/.config/shell"
if [[ -d "$SHELL_CONFIG_DIR" ]]; then
	for file in "$SHELL_CONFIG_DIR"/*.sh; do
		source "$file"
	done
fi

# Source zsh-specific config (before → root → after hooks).
ZSH_CONFIG_DIR="$HOME/.config/zsh"
ZSH_CONFIG_HOOKS=("before" "" "after")

for hook in "${ZSH_CONFIG_HOOKS[@]}"; do
	dir="$ZSH_CONFIG_DIR"
	if [[ -n $hook ]]; then
		dir+="/$hook"
	fi
	if [[ ! -d "$dir" ]]; then
		continue
	fi
	for file in "$dir"/*.zsh; do
		source "$file"
	done
done
