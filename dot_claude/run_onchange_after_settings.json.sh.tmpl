#!/usr/bin/env bash

# settings.json hash: {{ includeTemplate ".chezmoitemplates/file-hash.tmpl" (joinPath .chezmoi.homeDir ".claude/settings.json") }}
echo "Updating ~/.claude/settings.json..."

TARGET_FILE="$HOME/.claude/settings.json"

# Ensure file exists with valid JSON
[[ -s "$TARGET_FILE" ]] || echo '{}' > "$TARGET_FILE"

tmp=$(mktemp)

# Always set the status line and flicker-free rendering
jq '
  .statusLine = {"type": "command", "command": "bash ~/.claude/statusline-command.sh"} |
  .tui = "fullscreen"
' "$TARGET_FILE" > "$tmp"

{{ if .is_work -}}
# Work: add env overrides and model
jq '
  .env = {
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  } |
  .model = "opusplan"
' "$tmp" > "$TARGET_FILE"
{{ end -}}

{{ if .is_personal -}}
# Personal: remove work-specific settings
jq 'del(.env, .model)' "$tmp" > "$TARGET_FILE"
{{ end -}}

rm "$tmp"
